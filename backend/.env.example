# Node Environment
NODE_ENV=development
PORT=3001

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/sentientwallet

# Redis
REDIS_URL=redis://localhost:6379

# Blockchain RPC URLs (Alchemy)
ALCHEMY_API_KEY=your_alchemy_api_key_here
RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# Alternative: Infura
INFURA_API_KEY=your_infura_api_key_here

# AI Configuration - Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Tenderly Simulation API
TENDERLY_API_KEY=your_tenderly_api_key_here
TENDERLY_ACCOUNT_ID=your_tenderly_account_id
TENDERLY_PROJECT_ID=your_tenderly_project_id

# DeFi Data APIs
DEFILLAMA_API_URL=https://api.llama.fi
COINGECKO_API_KEY=your_coingecko_api_key_here

# Security
JWT_SECRET=change_this_to_a_secure_random_string_in_production
SESSION_SECRET=change_this_to_another_secure_random_string_in_production
ENCRYPTION_KEY=change_this_to_a_32_character_encryption_key

# AWS KMS (for production key management)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
KMS_KEY_ID=your_kms_key_id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Agent Configuration
AI_PERCEPTION_INTERVAL_MS=300000
AI_MAX_RETRIES=3
AI_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_AUTONOMOUS_MODE=true
ENABLE_VOICE_COMMANDS=true
ENABLE_SIMULATION=true

# Safety Limits
MAX_GAS_PRICE=100
MAX_DAILY_SPEND=10000
MAX_TRANSACTION_VALUE=50000

# Python AI Engine
PYTHON_AI_URL=http://localhost:8000
PYTHON_AI_API_KEY=your_python_ai_api_key_here

# Webhook URLs (optional)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# Monitoring (optional)
SENTRY_DSN=
DATADOG_API_KEY=

# Production Settings (uncomment for deployment)
# NODE_ENV=production
# DATABASE_URL=your_production_database_url
# REDIS_URL=your_production_redis_url
# CORS_ORIGINS=https://your-frontend-domain.com
